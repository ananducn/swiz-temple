+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n<style>\n  html { scroll-behavior: smooth; }\n  body { margin: 0; background: #FAF8F3; -webkit-font-smoothing: antialiased; }\n  image-slot { display: block; width: 100%; height: 100%; }\n  @keyframes heroRise { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }\n  @keyframes glowPulse { 0%,100% { opacity: .55; } 50% { opacity: .9; } }\n  ::selection { background: rgba(212,175,55,.35); }\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<div style=\"font-family:Manrope,sans-serif; color:#454E6E; background:#FAF8F3; overflow-x:hidden\">\n\n  <!-- ══════════ HEADER ══════════ -->\n  <header data-screen-label=\"Header\" style=\"position:fixed; top:0; left:0; right:0; z-index:80; background:rgba(250,248,243,.85); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border-bottom:1px solid rgba(30,58,138,.08)\">\n    <div style=\"max-width:1240px; margin:0 auto; padding:0 24px; height:76px; display:flex; align-items:center; justify-content:space-between; gap:24px\">\n      <a href=\"#home\" style=\"display:flex; align-items:center; gap:12px; text-decoration:none\">\n        <div style=\"width:42px; height:42px; border-radius:50%; background:radial-gradient(circle at 35% 30%, #2A4CA8, #16295F); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 14px rgba(30,58,138,.25)\">\n          <span style=\"color:#E8C95C; font-family:'EB Garamond',serif; font-size:20px; font-weight:600; line-height:1\">ॐ<\u002Fspan>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-family:'EB Garamond',serif; font-size:19px; font-weight:600; color:#1B2A5E; line-height:1.1\">Shri Krishna Mandir<\u002Fdiv>\n          <div style=\"font-size:10px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:#A8821F\">Indian Association in Switzerland<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fa>\n      <sc-if value=\"{{ isDesktop }}\" hint-placeholder-val=\"{{ true }}\">\n        <nav style=\"display:flex; align-items:center; gap:26px\">\n          <a href=\"#home\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">Home<\u002Fa>\n          <a href=\"#about\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">About<\u002Fa>\n          <a href=\"#project\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">Temple Project<\u002Fa>\n          <a href=\"#events\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">Events<\u002Fa>\n          <a href=\"#gallery\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">Gallery<\u002Fa>\n          <a href=\"#news\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">News<\u002Fa>\n          <a href=\"#contact\" style=\"text-decoration:none; color:#454E6E; font-size:14px; font-weight:600\" style-hover=\"color:#1E3A8A\">Contact<\u002Fa>\n          <a href=\"#donate\" style=\"text-decoration:none; background:linear-gradient(135deg,#E3C25C,#C49B28); color:#2A1F04; font-size:14px; font-weight:700; padding:11px 24px; border-radius:999px; box-shadow:0 6px 18px rgba(196,155,40,.35); transition:transform .2s, box-shadow .2s\" style-hover=\"transform:translateY(-1px); box-shadow:0 10px 24px rgba(196,155,40,.45)\">Donate<\u002Fa>\n        <\u002Fnav>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ isMobile }}\" hint-placeholder-val=\"{{ false }}\">\n        <button onclick=\"{{ toggleMenu }}\" aria-label=\"Menu\" style=\"background:none; border:1px solid rgba(30,58,138,.15); border-radius:12px; width:44px; height:44px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:5px; cursor:pointer\">\n          <span style=\"display:block; width:18px; height:2px; background:#1B2A5E; border-radius:2px\"><\u002Fspan>\n          <span style=\"display:block; width:18px; height:2px; background:#1B2A5E; border-radius:2px\"><\u002Fspan>\n          <span style=\"display:block; width:18px; height:2px; background:#1B2A5E; border-radius:2px\"><\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fsc-if>\n    <\u002Fdiv>\n    <sc-if value=\"{{ menuOpen }}\" hint-placeholder-val=\"{{ false }}\">\n      <nav style=\"display:flex; flex-direction:column; padding:12px 24px 24px; gap:4px; background:rgba(250,248,243,.98); border-bottom:1px solid rgba(30,58,138,.08)\">\n        <a href=\"#home\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Home<\u002Fa>\n        <a href=\"#about\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">About<\u002Fa>\n        <a href=\"#project\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Temple Project<\u002Fa>\n        <a href=\"#donate\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Donate<\u002Fa>\n        <a href=\"#events\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Events<\u002Fa>\n        <a href=\"#gallery\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Gallery<\u002Fa>\n        <a href=\"#news\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">News<\u002Fa>\n        <a href=\"#contact\" onclick=\"{{ closeMenu }}\" style=\"text-decoration:none; color:#1B2A5E; font-size:16px; font-weight:600; padding:12px 8px; border-radius:10px\" style-hover=\"background:rgba(30,58,138,.05)\">Contact<\u002Fa>\n      <\u002Fnav>\n    <\u002Fsc-if>\n  <\u002Fheader>\n\n  <!-- ══════════ 1 · HERO ══════════ -->\n  <section id=\"home\" data-screen-label=\"Hero\" style=\"position:relative; min-height:94vh; display:flex; align-items:center; scroll-margin-top:76px; background:linear-gradient(180deg,#16295F 0%,#1E3A8A 60%,#3A5AB4 100%)\">\n    <div style=\"position:absolute; inset:0\">\n      <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"hero-render\" shape=\"rect\" radius=\"0\" placeholder=\"Hero: concept render of Krishna temple amid Swiss Alps, golden sunrise\" src=\"uploads/heroimage.png\" hint-size=\"100%,100%\" style=\"position:absolute; inset:0\"><\u002Fx-import>\n    <\u002Fdiv>\n    <div style=\"position:absolute; inset:0; pointer-events:none; background:linear-gradient(180deg, rgba(13,24,58,.65) 0%, rgba(13,24,58,.45) 45%, rgba(250,248,243,0) 82%, #FAF8F3 100%)\"><\u002Fdiv>\n    <div style=\"position:absolute; inset:0; pointer-events:none; background:linear-gradient(100deg, rgba(13,24,58,.72) 0%, rgba(13,24,58,.5) 38%, rgba(13,24,58,.12) 62%, rgba(13,24,58,0) 78%)\"><\u002Fdiv>\n    <div style=\"position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 70% 50% at 70% 30%, rgba(212,175,55,.18), transparent 70%); animation:glowPulse 8s ease-in-out infinite\"><\u002Fdiv>\n    <div style=\"position:relative; max-width:1240px; margin:0 auto; padding:150px 24px 90px; display:flex; flex-wrap:wrap; align-items:flex-end; gap:48px; width:100%; box-sizing:border-box\">\n      <div style=\"flex:1 1 540px; min-width:0; animation:heroRise .9s cubic-bezier(.22,1,.36,1) both\">\n        <div style=\"display:inline-flex; align-items:center; gap:10px; background:rgba(255,255,255,.12); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.22); border-radius:999px; padding:8px 18px; margin-bottom:28px\">\n          <span style=\"width:6px; height:6px; border-radius:50%; background:#E8C95C\"><\u002Fspan>\n          <span style=\"color:rgba(255,255,255,.92); font-size:12px; font-weight:600; letter-spacing:.18em; text-transform:uppercase\">A sacred project in the heart of the Alps<\u002Fspan>\n        <\u002Fdiv>\n        <h1 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(42px,6vw,78px); line-height:1.05; color:#FFFFFF; margin:0 0 24px; text-wrap:balance; text-shadow:0 2px 12px rgba(13,24,58,.55), 0 4px 40px rgba(13,24,58,.5)\">Building a Divine Home for Lord Krishna in Switzerland<\u002Fh1>\n        <p style=\"font-size:clamp(16px,1.4vw,19px); line-height:1.7; color:rgba(255,255,255,.95); max-width:560px; margin:0 0 36px; text-shadow:0 1px 8px rgba(13,24,58,.5)\">A landmark temple where Vedic tradition meets the serenity of the Swiss Alps — a place of worship, culture, and community for generations to come. Built entirely through the devotion of people like you.<\u002Fp>\n        <div style=\"display:flex; flex-wrap:wrap; gap:16px; align-items:center\">\n          <a href=\"#donate\" style=\"text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:16px; font-weight:700; padding:17px 38px; border-radius:999px; box-shadow:0 10px 30px rgba(196,155,40,.4); transition:transform .2s, box-shadow .2s\" style-hover=\"transform:translateY(-2px); box-shadow:0 16px 40px rgba(196,155,40,.5)\">Donate Now<\u002Fa>\n          <a href=\"#project\" style=\"text-decoration:none; color:#fff; font-size:16px; font-weight:600; padding:16px 32px; border-radius:999px; border:1px solid rgba(255,255,255,.4); backdrop-filter:blur(8px); transition:background .2s, border-color .2s\" style-hover=\"background:rgba(255,255,255,.12); border-color:rgba(255,255,255,.7)\">Explore the Project<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"flex:0 1 340px; min-width:280px; animation:heroRise 1s .25s cubic-bezier(.22,1,.36,1) both\">\n        <div style=\"background:rgba(13,24,58,.55); backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px); border:1px solid rgba(255,255,255,.25); border-radius:24px; padding:28px; box-shadow:0 20px 60px rgba(13,24,58,.35)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#E8C95C; margin-bottom:14px\">Live fundraising<\u002Fdiv>\n          <div style=\"display:flex; align-items:baseline; gap:8px; flex-wrap:wrap\">\n            <span style=\"font-family:'EB Garamond',serif; font-size:38px; font-weight:600; color:#fff; line-height:1\">CHF {{ raisedFmt }}<\u002Fspan>\n          <\u002Fdiv>\n          <div style=\"font-size:13px; color:rgba(255,255,255,.85); margin:6px 0 16px\">raised of CHF {{ goalFmt }} goal<\u002Fdiv>\n          <div style=\"height:8px; border-radius:999px; background:rgba(255,255,255,.22); overflow:hidden\">\n            <div style=\"height:100%; border-radius:999px; background:linear-gradient(90deg,#E9CA66,#C49B28); width:{{ barW }}; transition:width 1.4s cubic-bezier(.22,1,.36,1)\"><\u002Fdiv>\n          <\u002Fdiv>\n          <div style=\"display:flex; justify-content:space-between; margin-top:12px; font-size:13px; color:rgba(255,255,255,.92)\">\n            <span style=\"font-weight:700; color:#E8C95C\">{{ pct }}% funded<\u002Fspan>\n            <span>{{ supportersFmt }} supporters<\u002Fspan>\n          <\u002Fdiv>\n          <a href=\"#donate\" style=\"display:block; text-align:center; text-decoration:none; margin-top:18px; background:rgba(255,255,255,.94); color:#1B2A5E; font-size:14px; font-weight:700; padding:13px; border-radius:999px; transition:background .2s\" style-hover=\"background:#fff\">Contribute today<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 2 · DONATION PROGRESS ══════════ -->\n  <section data-screen-label=\"Donation Progress\" style=\"padding:clamp(56px,7vw,96px) 24px 0\">\n    <div data-reveal=\"\" style=\"max-width:1180px; margin:0 auto; background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:28px; box-shadow:0 16px 50px rgba(23,37,84,.07); padding:clamp(28px,4vw,56px); display:flex; flex-wrap:wrap; gap:40px; align-items:center\">\n      <div style=\"flex:1 1 380px; min-width:0\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:12px\">Our progress together<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(30px,3.4vw,44px); color:#1B2A5E; margin:0 0 14px; line-height:1.15\">Every franc brings the temple closer<\u002Fh2>\n        <p style=\"margin:0; line-height:1.7; font-size:16px\">Our community has already carried this vision remarkably far. Your contribution — of any size — becomes part of a sacred home that will stand for centuries.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"flex:1 1 420px; min-width:0\">\n        <div style=\"display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:8px; margin-bottom:14px\">\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:clamp(36px,4vw,52px); font-weight:600; color:#1E3A8A; line-height:1\">CHF {{ raisedFmt }}<\u002Fdiv>\n            <div style=\"font-size:13px; font-weight:600; color:#8A92AC; margin-top:6px\">Amount raised<\u002Fdiv>\n          <\u002Fdiv>\n          <div style=\"text-align:right\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:clamp(24px,2.4vw,32px); font-weight:600; color:#8A92AC; line-height:1\">CHF {{ goalFmt }}<\u002Fdiv>\n            <div style=\"font-size:13px; font-weight:600; color:#8A92AC; margin-top:6px\">Goal<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"height:14px; border-radius:999px; background:#EEF0F6; overflow:hidden; box-shadow:inset 0 1px 3px rgba(23,37,84,.08)\">\n          <div style=\"height:100%; border-radius:999px; background:linear-gradient(90deg,#2A4CA8,#1E3A8A 55%,#C49B28); width:{{ barW }}; transition:width 1.4s cubic-bezier(.22,1,.36,1)\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"display:flex; gap:28px; margin-top:22px; flex-wrap:wrap\">\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; color:#1B2A5E; line-height:1\">{{ pct }}%<\u002Fdiv>\n            <div style=\"font-size:12px; font-weight:600; color:#8A92AC; margin-top:4px\">Funded<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; color:#1B2A5E; line-height:1\">{{ supportersFmt }}<\u002Fdiv>\n            <div style=\"font-size:12px; font-weight:600; color:#8A92AC; margin-top:4px\">Supporters<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; color:#1B2A5E; line-height:1\">2028<\u002Fdiv>\n            <div style=\"font-size:12px; font-weight:600; color:#8A92AC; margin-top:4px\">Planned opening<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 3 · WHY BUILD ══════════ -->\n  <section id=\"about\" data-screen-label=\"Why Build This Temple\" style=\"padding:clamp(72px,9vw,120px) 24px; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"text-align:center; max-width:640px; margin:0 auto clamp(40px,5vw,64px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Our purpose<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,50px); color:#1B2A5E; margin:0 0 18px; line-height:1.12; text-wrap:balance\">Why build this temple?<\u002Fh2>\n        <div style=\"display:flex; align-items:center; justify-content:center; gap:12px; margin-bottom:18px\">\n          <span style=\"display:block; width:48px; height:1px; background:linear-gradient(90deg,transparent,#D4AF37)\"><\u002Fspan>\n          <span style=\"color:#D4AF37; font-size:12px\">✦<\u002Fspan>\n          <span style=\"display:block; width:48px; height:1px; background:linear-gradient(90deg,#D4AF37,transparent)\"><\u002Fspan>\n        <\u002Fdiv>\n        <p style=\"margin:0; font-size:17px; line-height:1.7\">More than a building — a living center of faith, culture, and belonging for the Indian community and all friends of Vedic tradition in Switzerland.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Spiritual Center<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">A consecrated sanctum for darshan, prayer, and reflection — the first traditional Krishna temple of its kind in Switzerland.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Cultural Heritage<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">Preserving classical music, dance, language, and art — keeping India's living heritage vibrant far from home.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Community Gathering<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">A warm meeting place where families across Switzerland gather, celebrate, and support one another.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Youth Education<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">Gita classes, Sanskrit, values education, and mentorship that root the next generation in timeless wisdom.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Festivals<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">Janmashtami, Holi, and Diwali celebrated in their full splendour — open to everyone, every year.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"width:46px; height:46px; border-radius:15px; background:linear-gradient(135deg,rgba(30,58,138,.09),rgba(30,58,138,.04)); display:flex; align-items:center; justify-content:center; color:#B8912A; font-size:17px; margin-bottom:20px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px\">Daily Worship<\u002Fh3>\n          <p style=\"margin:0; font-size:15px; line-height:1.65\">Morning and evening aarti, bhajans, and prasadam — a steady rhythm of devotion, every single day.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 4 · TEMPLE VISION ══════════ -->\n  <section id=\"project\" data-screen-label=\"Temple Vision\" style=\"padding:clamp(72px,9vw,120px) 24px; background:#F3F4F8; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto; display:flex; flex-wrap:wrap; gap:clamp(32px,5vw,64px); align-items:center\">\n      <div data-reveal=\"\" style=\"flex:1 1 480px; min-width:0\">\n        <div style=\"border-radius:28px; overflow:hidden; box-shadow:0 30px 70px rgba(23,37,84,.18); aspect-ratio:4/3\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"vision-render\" shape=\"rect\" radius=\"0\" placeholder=\"Architectural rendering: temple exterior with shikhara, Alpine backdrop\" src=\"uploads/temple vision.png\" hint-size=\"100%,420px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"flex:1 1 420px; min-width:0\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">The vision<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0 0 20px; line-height:1.12; text-wrap:balance\">Where Himalayan tradition meets the Alps<\u002Fh2>\n        <p style=\"margin:0 0 18px; font-size:16px; line-height:1.75\">Designed in the classical Nagara style by traditional temple architects, the mandir will rise in harmony with its Alpine surroundings — hand-carved stone, a golden kalash crowning the shikhara, and gardens of lotus and native wildflowers.<\u002Fp>\n        <p style=\"margin:0 0 28px; font-size:16px; line-height:1.75\">Our mission is simple: to create a sanctuary of peace and devotion that serves every generation — a home for Lord Krishna, and for all who seek Him.<\u002Fp>\n        <div style=\"display:flex; gap:32px; flex-wrap:wrap\">\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:34px; font-weight:600; color:#1E3A8A; line-height:1\">2,400 m²<\u002Fdiv>\n            <div style=\"font-size:13px; font-weight:600; color:#8A92AC; margin-top:6px\">Temple complex<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:34px; font-weight:600; color:#1E3A8A; line-height:1\">500+<\u002Fdiv>\n            <div style=\"font-size:13px; font-weight:600; color:#8A92AC; margin-top:6px\">Devotee capacity<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <div style=\"font-family:'EB Garamond',serif; font-size:34px; font-weight:600; color:#1E3A8A; line-height:1\">100%<\u002Fdiv>\n            <div style=\"font-size:13px; font-weight:600; color:#8A92AC; margin-top:6px\">Community funded<\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 5 · TIMELINE ══════════ -->\n  <section data-screen-label=\"Construction Timeline\" style=\"padding:clamp(72px,9vw,120px) 0; background:#F3F4F8; border-top:1px solid rgba(30,58,138,.06)\">\n    <div style=\"max-width:1180px; margin:0 auto; padding:0 24px\">\n      <div data-reveal=\"\" style=\"max-width:600px; margin-bottom:clamp(36px,4vw,56px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">The journey<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0; line-height:1.12\">From vision to consecration<\u002Fh2>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div data-reveal=\"\" style=\"overflow-x:auto; padding:8px 24px 24px; -webkit-overflow-scrolling:touch\">\n      <div style=\"display:flex; gap:0; min-width:1120px; max-width:1180px; margin:0 auto; position:relative\">\n        <div style=\"position:absolute; top:11px; left:80px; right:80px; height:2px; background:linear-gradient(90deg,#C49B28 0%,#C49B28 52%,#D8DCE8 52%,#D8DCE8 100%)\"><\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#C49B28; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C49B28; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F\">2023 · Complete<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Land Secured<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">A serene 8,000 m² parcel acquired<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#C49B28; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C49B28; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F\">2024 · Complete<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Planning &amp; Design<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">Nagara-style plans by temple architects<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#C49B28; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C49B28; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F\">2025 · Complete<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Permissions<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">Building permit granted by the canton<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#1E3A8A; border:5px solid #F3F4F8; box-shadow:0 0 0 2px #1E3A8A, 0 0 0 8px rgba(30,58,138,.12); margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#1E3A8A\">Now · In progress<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Fundraising<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">{{ pct }}% of CHF {{ goalFmt }} raised<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#fff; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C6CCDD; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#8A92AC\">2027<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Construction<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">Groundbreaking and main structure<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#fff; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C6CCDD; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#8A92AC\">2028<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Murti Installation<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">Prana pratishtha of the deities<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1; min-width:160px; position:relative; text-align:center; padding:0 10px\">\n          <div style=\"width:24px; height:24px; border-radius:50%; background:#fff; border:5px solid #F3F4F8; box-shadow:0 0 0 1px #C6CCDD; margin:0 auto 16px; position:relative\"><\u002Fdiv>\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#8A92AC\">2028<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; margin-top:6px\">Grand Opening<\u002Fdiv>\n          <div style=\"font-size:13px; line-height:1.55; margin-top:6px; color:#6B7390\">Kumbhabhishekam celebration<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 6 · DONATE ══════════ -->\n  <section id=\"donate\" data-screen-label=\"Donation Section\" style=\"padding:clamp(72px,9vw,120px) 24px; background:linear-gradient(180deg,#16295F,#1E3A8A); scroll-margin-top:76px; position:relative; overflow:hidden\">\n    <div style=\"position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 60% 40% at 50% 0%, rgba(212,175,55,.14), transparent 70%)\"><\u002Fdiv>\n    <div style=\"max-width:1180px; margin:0 auto; position:relative\">\n      <div data-reveal=\"\" style=\"text-align:center; max-width:620px; margin:0 auto clamp(40px,5vw,60px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#E8C95C; margin-bottom:14px\">Seva opportunities<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,50px); color:#fff; margin:0 0 18px; line-height:1.12; text-wrap:balance\">Lay a stone in Krishna's home<\u002Fh2>\n        <p style=\"margin:0; font-size:17px; line-height:1.7; color:rgba(255,255,255,.8)\">Choose a seva that speaks to your heart. Every sponsor is honoured in the temple's permanent donor record.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:20px; margin-bottom:28px\">\n        <div data-reveal=\"\" style=\"background:rgba(255,255,255,.08); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.16); border-radius:22px; padding:30px 26px; text-align:center; transition:transform .25s, background .25s\" style-hover=\"transform:translateY(-4px); background:rgba(255,255,255,.13)\">\n          <div style=\"color:#E8C95C; font-size:14px; margin-bottom:14px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#fff; margin:0 0 6px\">Sponsor a Brick<\u002Fh3>\n          <div style=\"font-size:13px; color:rgba(255,255,255,.65); margin-bottom:18px\">The foundation of devotion<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:38px; font-weight:600; color:#E8C95C; line-height:1; margin-bottom:20px\">CHF 21<\u002Fdiv>\n          <a href=\"#donate\" style=\"display:block; text-decoration:none; border:1px solid rgba(255,255,255,.35); color:#fff; font-size:14px; font-weight:700; padding:12px; border-radius:999px; transition:background .2s\" style-hover=\"background:rgba(255,255,255,.12)\">Sponsor<\u002Fa>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:rgba(255,255,255,.08); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.16); border-radius:22px; padding:30px 26px; text-align:center; transition:transform .25s, background .25s\" style-hover=\"transform:translateY(-4px); background:rgba(255,255,255,.13)\">\n          <div style=\"color:#E8C95C; font-size:14px; margin-bottom:14px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#fff; margin:0 0 6px\">Temple Flooring<\u002Fh3>\n          <div style=\"font-size:13px; color:rgba(255,255,255,.65); margin-bottom:18px\">Marble where devotees gather<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:38px; font-weight:600; color:#E8C95C; line-height:1; margin-bottom:20px\">CHF 101<\u002Fdiv>\n          <a href=\"#donate\" style=\"display:block; text-decoration:none; border:1px solid rgba(255,255,255,.35); color:#fff; font-size:14px; font-weight:700; padding:12px; border-radius:999px; transition:background .2s\" style-hover=\"background:rgba(255,255,255,.12)\">Sponsor<\u002Fa>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:rgba(255,255,255,.13); backdrop-filter:blur(12px); border:1px solid rgba(212,175,55,.55); border-radius:22px; padding:30px 26px; text-align:center; position:relative; transition:transform .25s, background .25s\" style-hover=\"transform:translateY(-4px); background:rgba(255,255,255,.17)\">\n          <div style=\"position:absolute; top:-12px; left:50%; transform:translateX(-50%); background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:11px; font-weight:800; letter-spacing:.1em; text-transform:uppercase; padding:5px 14px; border-radius:999px; white-space:nowrap\">Most chosen<\u002Fdiv>\n          <div style=\"color:#E8C95C; font-size:14px; margin-bottom:14px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#fff; margin:0 0 6px\">Sponsor a Pillar<\u002Fh3>\n          <div style=\"font-size:13px; color:rgba(255,255,255,.65); margin-bottom:18px\">Carved stone, standing for ages<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:38px; font-weight:600; color:#E8C95C; line-height:1; margin-bottom:20px\">CHF 501<\u002Fdiv>\n          <a href=\"#donate\" style=\"display:block; text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:14px; font-weight:700; padding:12px; border-radius:999px; transition:transform .2s\" style-hover=\"transform:scale(1.02)\">Sponsor<\u002Fa>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:rgba(255,255,255,.08); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.16); border-radius:22px; padding:30px 26px; text-align:center; transition:transform .25s, background .25s\" style-hover=\"transform:translateY(-4px); background:rgba(255,255,255,.13)\">\n          <div style=\"color:#E8C95C; font-size:14px; margin-bottom:14px\">✦<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#fff; margin:0 0 6px\">Sponsor Sanctum<\u002Fh3>\n          <div style=\"font-size:13px; color:rgba(255,255,255,.65); margin-bottom:18px\">The heart of the temple<\u002Fdiv>\n          <div style=\"font-family:'EB Garamond',serif; font-size:38px; font-weight:600; color:#E8C95C; line-height:1; margin-bottom:20px\">CHF 1,001<\u002Fdiv>\n          <a href=\"#donate\" style=\"display:block; text-decoration:none; border:1px solid rgba(255,255,255,.35); color:#fff; font-size:14px; font-weight:700; padding:12px; border-radius:999px; transition:background .2s\" style-hover=\"background:rgba(255,255,255,.12)\">Sponsor<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"background:rgba(255,255,255,.08); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,.16); border-radius:22px; padding:28px; display:flex; flex-wrap:wrap; align-items:center; gap:20px; justify-content:space-between\">\n        <div style=\"flex:1 1 300px\">\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#fff; margin:0 0 6px\">Custom Donation<\u002Fh3>\n          <div style=\"font-size:14px; color:rgba(255,255,255,.7)\">Give any amount, one-time or monthly. Every contribution matters.<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"display:flex; flex-wrap:wrap; gap:12px; align-items:center\">\n          <input type=\"number\" placeholder=\"Amount in CHF\" style=\"background:rgba(255,255,255,.95); border:1px solid rgba(255,255,255,.5); border-radius:999px; padding:15px 24px; color:#1B2A5E; font-family:Manrope,sans-serif; font-size:15px; font-weight:700; width:180px; outline:none\">\n          <a href=\"#donate\" style=\"text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:16px; font-weight:800; padding:16px 40px; border-radius:999px; box-shadow:0 10px 30px rgba(196,155,40,.35); transition:transform .2s\" style-hover=\"transform:translateY(-2px)\">Donate Now<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"text-align:center; margin-top:26px; font-size:13px; color:rgba(255,255,255,.6)\">Secure payment · Twint, bank transfer &amp; cards · Tax-deductible in most Swiss cantons<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 7 · IMPACT ══════════ -->\n  <section data-screen-label=\"Impact\" style=\"padding:clamp(72px,9vw,120px) 24px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"display:flex; flex-wrap:wrap; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:clamp(36px,4vw,56px)\">\n        <div style=\"max-width:560px\">\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Full transparency<\u002Fdiv>\n          <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0; line-height:1.12\">Exactly where your donation goes<\u002Fh2>\n        <\u002Fdiv>\n        <p style=\"max-width:380px; margin:0; font-size:15px; line-height:1.7\">Audited annually and published in our yearly report. Our committee serves entirely as volunteers.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:22px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:56px; font-weight:600; color:#1E3A8A; line-height:1\">68%<\u002Fdiv>\n          <div style=\"height:6px; border-radius:999px; background:#EEF0F6; margin:18px 0 16px; overflow:hidden\"><div style=\"height:100%; width:68%; border-radius:999px; background:#1E3A8A\"><\u002Fdiv><\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Temple Construction<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Structure, stonework, roofing, and the sacred shikhara.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:56px; font-weight:600; color:#A8821F; line-height:1\">14%<\u002Fdiv>\n          <div style=\"height:6px; border-radius:999px; background:#EEF0F6; margin:18px 0 16px; overflow:hidden\"><div style=\"height:100%; width:14%; border-radius:999px; background:#C49B28\"><\u002Fdiv><\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Sanctum &amp; Deities<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Hand-carved murtis, altar, and sanctum finishing.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:56px; font-weight:600; color:#6E1E2B; line-height:1\">10%<\u002Fdiv>\n          <div style=\"height:6px; border-radius:999px; background:#EEF0F6; margin:18px 0 16px; overflow:hidden\"><div style=\"height:100%; width:10%; border-radius:999px; background:#6E1E2B\"><\u002Fdiv><\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Community Facilities<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Halls, classrooms, kitchen, gardens, and parking.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:56px; font-weight:600; color:#8A92AC; line-height:1\">8%<\u002Fdiv>\n          <div style=\"height:6px; border-radius:999px; background:#EEF0F6; margin:18px 0 16px; overflow:hidden\"><div style=\"height:100%; width:8%; border-radius:999px; background:#8A92AC\"><\u002Fdiv><\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Operations &amp; Legal<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Permits, insurance, audits — never salaries.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 8 · ABOUT LORD KRISHNA ══════════ -->\n  <section data-screen-label=\"About Lord Krishna\" style=\"padding:clamp(72px,9vw,120px) 24px; background:linear-gradient(180deg,#FAF8F3,#F6F1E4 50%,#FAF8F3); position:relative; overflow:hidden\">\n    <div style=\"position:absolute; top:40px; left:-80px; width:280px; height:280px; border-radius:50%; border:1px solid rgba(212,175,55,.25); pointer-events:none\"><\u002Fdiv>\n    <div style=\"position:absolute; top:90px; left:-30px; width:180px; height:180px; border-radius:50%; border:1px solid rgba(212,175,55,.2); pointer-events:none\"><\u002Fdiv>\n    <div style=\"position:absolute; bottom:-60px; right:-60px; width:320px; height:320px; border-radius:50%; border:1px solid rgba(30,58,138,.1); pointer-events:none\"><\u002Fdiv>\n    <div style=\"max-width:1080px; margin:0 auto; display:flex; flex-wrap:wrap; gap:clamp(36px,5vw,72px); align-items:center; position:relative\">\n      <div data-reveal=\"\" style=\"flex:0 1 380px; min-width:280px; margin:0 auto\">\n        <div style=\"border-radius:200px 200px 28px 28px; overflow:hidden; box-shadow:0 30px 70px rgba(110,30,43,.18); border:1px solid rgba(212,175,55,.35); aspect-ratio:3/4\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"krishna-art\" shape=\"rect\" radius=\"0\" placeholder=\"Artistic illustration of Lord Krishna with flute (classical painting style)\" src=\"uploads/About loard krishna.png\" hint-size=\"100%,480px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"flex:1 1 440px; min-width:0\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">The divine inspiration<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0 0 20px; line-height:1.12\">About Lord Krishna<\u002Fh2>\n        <p style=\"margin:0 0 18px; font-size:16px; line-height:1.75\">Lord Krishna — the eighth avatar of Vishnu, divine teacher of the Bhagavad Gita, and embodiment of love, wisdom, and joy — has guided seekers for over five thousand years. His message of selfless action and devotion transcends every border.<\u002Fp>\n        <blockquote style=\"margin:32px 0; padding:28px 32px; background:rgba(255,255,255,.7); backdrop-filter:blur(8px); border-radius:20px; border:1px solid rgba(212,175,55,.3); box-shadow:0 12px 36px rgba(110,30,43,.07)\">\n          <p style=\"font-family:'EB Garamond',serif; font-style:italic; font-size:clamp(20px,2vw,25px); line-height:1.5; color:#1B2A5E; margin:0 0 14px\">\"Whatever you do, whatever you eat, whatever you offer, whatever you give — do that as an offering unto Me.\"<\u002Fp>\n          <cite style=\"font-style:normal; font-size:13px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F\">— Bhagavad Gita 9.27<\u002Fcite>\n        <\u002Fblockquote>\n        <p style=\"margin:0; font-size:16px; line-height:1.75\">This temple is our collective offering — built brick by brick with devotion, so His presence may bless Switzerland for generations.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 9 · TEMPLE FEATURES ══════════ -->\n  <section data-screen-label=\"Temple Features\" style=\"padding:clamp(72px,9vw,120px) 24px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"text-align:center; max-width:600px; margin:0 auto clamp(40px,5vw,60px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Inside the mandir<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,50px); color:#1B2A5E; margin:0 0 18px; line-height:1.12\">A home for every seeker<\u002Fh2>\n        <div style=\"display:flex; align-items:center; justify-content:center; gap:12px\">\n          <span style=\"display:block; width:48px; height:1px; background:linear-gradient(90deg,transparent,#D4AF37)\"><\u002Fspan>\n          <span style=\"color:#D4AF37; font-size:12px\">✦<\u002Fspan>\n          <span style=\"display:block; width:48px; height:1px; background:linear-gradient(90deg,#D4AF37,transparent)\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:18px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">01<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Main Sanctum<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">The garbhagriha housing Sri Krishna's murti beneath the golden shikhara.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">02<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Prayer Hall<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">A luminous 500-seat mandapa for aarti, kirtan, and ceremonies.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">03<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Meditation Hall<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">A silent space with Alpine views for contemplation and japa.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">04<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Community Hall<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Weddings, festivals, and gatherings for up to 300 guests.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">05<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Cultural Classrooms<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Music, dance, Sanskrit, and language classes for all ages.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">06<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Prasadam Hall<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Sanctified vegetarian meals shared freely after every service.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">07<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Library<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">Vedic scriptures and literature in Sanskrit, Hindi, German, French, and English.<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:28px; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"font-size:11px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">08<\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 8px\">Children's Learning Area<\u002Fh3>\n          <p style=\"margin:0; font-size:14px; line-height:1.6\">A joyful space where young ones discover stories and values.<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 10 · GALLERY ══════════ -->\n  <section id=\"gallery\" data-screen-label=\"Gallery\" style=\"padding:clamp(72px,9vw,120px) 24px; background:#F3F4F8; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"max-width:600px; margin-bottom:clamp(36px,4vw,56px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Gallery<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0 0 14px; line-height:1.12\">Moments of devotion<\u002Fh2>\n        <p style=\"margin:0; font-size:16px; line-height:1.7\">Concept renders, community celebrations, and the journey so far. Drop your own photos into any frame.<\u002Fp>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"columns:3 300px; column-gap:20px\">\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:340px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-1\" shape=\"rect\" placeholder=\"Temple concept render — front elevation\" src=\"uploads/gallery 1.png\" hint-size=\"100%,340px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:240px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-2\" shape=\"rect\" placeholder=\"Janmashtami celebration photo\" src=\"uploads/gallery 2.png\" hint-size=\"100%,240px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:280px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-3\" shape=\"rect\" placeholder=\"The temple site — Alpine meadow\" src=\"uploads/gallery 3.png\" hint-size=\"100%,280px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:260px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-4\" shape=\"rect\" placeholder=\"Community bhajan evening\" src=\"uploads/gallery 4.png\" hint-size=\"100%,260px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:320px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-5\" shape=\"rect\" placeholder=\"Interior render — prayer hall\" src=\"uploads/gallery 6.png\" hint-size=\"100%,320px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:230px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-6\" shape=\"rect\" placeholder=\"Holi festival — community photo\" src=\"uploads/gallery 5.png\" hint-size=\"100%,230px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:300px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-7\" shape=\"rect\" placeholder=\"Murti craftsmanship in progress\" src=\"uploads/gallery 8.png\" hint-size=\"100%,300px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n        <div style=\"break-inside:avoid; margin-bottom:20px; border-radius:20px; overflow:hidden; box-shadow:0 12px 34px rgba(23,37,84,.08); height:250px\">\n          <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"gal-8\" shape=\"rect\" placeholder=\"Yoga session by the lake\" src=\"uploads/gallery 7.png\" hint-size=\"100%,250px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 11 · EVENTS ══════════ -->\n  <section id=\"events\" data-screen-label=\"Events\" style=\"padding:clamp(72px,9vw,120px) 24px; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"max-width:600px; margin-bottom:clamp(36px,4vw,56px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Join us<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0 0 14px; line-height:1.12\">Upcoming festivals &amp; gatherings<\u002Fh2>\n        <p style=\"margin:0; font-size:16px; line-height:1.7\">Until the temple opens, we celebrate together in community halls across Switzerland. Everyone is welcome.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(320px,1fr)); gap:18px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#1E3A8A,#16295F); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; line-height:1\">04<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#E8C95C\">Sep<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Janmashtami<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Krishna's birth celebrated with midnight aarti, abhishek &amp; feast · Zürich<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#1E3A8A,#16295F); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; line-height:1\">08<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#E8C95C\">Nov<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Diwali<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Festival of lights with lamps, cultural performances &amp; dinner · Geneva<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#1E3A8A,#16295F); display:flex; flex-direction:column; align-items:center; justify-content:center; color:#fff\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:30px; font-weight:600; line-height:1\">22<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#E8C95C\">Mar<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Holi<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Colours, music, and sweets to welcome spring · Bern<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#F6F1E4,#EFE6CE); display:flex; flex-direction:column; align-items:center; justify-content:center\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; line-height:1; color:#A8821F\">Sun<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F\">Weekly<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Bhagavad Gita Classes<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Verse-by-verse study circle, in person &amp; online · Sundays 10:00<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#F6F1E4,#EFE6CE); display:flex; flex-direction:column; align-items:center; justify-content:center\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; line-height:1; color:#A8821F\">Fri<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F\">Monthly<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Bhajan Evenings<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Devotional singing with harmonium &amp; tabla · First Friday, 19:00<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:20px; padding:24px; display:flex; gap:20px; align-items:center; box-shadow:0 8px 28px rgba(23,37,84,.04); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-3px); box-shadow:0 16px 38px rgba(23,37,84,.09)\">\n          <div style=\"flex-shrink:0; width:72px; height:78px; border-radius:16px; background:linear-gradient(160deg,#F6F1E4,#EFE6CE); display:flex; flex-direction:column; align-items:center; justify-content:center\">\n            <div style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; line-height:1; color:#A8821F\">Sat<\u002Fdiv>\n            <div style=\"font-size:11px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F\">Weekly<\u002Fdiv>\n          <\u002Fdiv>\n          <div>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:23px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Yoga Sessions<\u002Fh3>\n            <p style=\"margin:0; font-size:14px; line-height:1.55\">Hatha yoga &amp; pranayama for all levels · Saturdays 09:00<\u002Fp>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 12 · COMMITTEE ══════════ -->\n  <section data-screen-label=\"Committee\" style=\"padding:clamp(72px,9vw,120px) 24px; background:#F3F4F8\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"text-align:center; max-width:580px; margin:0 auto clamp(40px,5vw,60px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Stewardship<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0 0 18px; line-height:1.12\">The committee<\u002Fh2>\n        <p style=\"margin:0; font-size:16px; line-height:1.7\">Volunteers elected by the association's members, serving without compensation and accountable to the annual general assembly.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:22px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px 24px; text-align:center; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"width:110px; height:110px; margin:0 auto 18px; border-radius:50%; overflow:hidden; border:3px solid rgba(212,175,55,.4)\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"team-1\" shape=\"circle\" placeholder=\"Photo\" src=\"uploads/team-1.png\" hint-size=\"110px,110px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Rajesh Sharma<\u002Fh3>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">President<\u002Fdiv>\n          <p style=\"margin:0; font-size:13px; line-height:1.6\">Zürich · Engineer and community organiser for 20 years<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px 24px; text-align:center; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"width:110px; height:110px; margin:0 auto 18px; border-radius:50%; overflow:hidden; border:3px solid rgba(212,175,55,.4)\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"team-2\" shape=\"circle\" placeholder=\"Photo\" src=\"uploads/team-2.png\" hint-size=\"110px,110px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Priya Patel<\u002Fh3>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">Vice President<\u002Fdiv>\n          <p style=\"margin:0; font-size:13px; line-height:1.6\">Geneva · Cultural programs and youth education lead<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px 24px; text-align:center; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"width:110px; height:110px; margin:0 auto 18px; border-radius:50%; overflow:hidden; border:3px solid rgba(212,175,55,.4)\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"team-3\" shape=\"circle\" placeholder=\"Photo\" src=\"uploads/team-3.png\" hint-size=\"110px,110px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Anand Iyer<\u002Fh3>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">Treasurer<\u002Fdiv>\n          <p style=\"margin:0; font-size:13px; line-height:1.6\">Basel · Chartered accountant, oversees audited finances<\u002Fp>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:32px 24px; text-align:center; box-shadow:0 10px 34px rgba(23,37,84,.05)\">\n          <div style=\"width:110px; height:110px; margin:0 auto 18px; border-radius:50%; overflow:hidden; border:3px solid rgba(212,175,55,.4)\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"team-4\" shape=\"circle\" placeholder=\"Photo\" src=\"uploads/team-4.png\" hint-size=\"110px,110px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <h3 style=\"font-family:'EB Garamond',serif; font-size:22px; font-weight:600; color:#1B2A5E; margin:0 0 4px\">Meera Krishnan<\u002Fh3>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">Secretary<\u002Fdiv>\n          <p style=\"margin:0; font-size:13px; line-height:1.6\">Bern · Liaison with authorities and community partners<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 13 · TESTIMONIALS ══════════ -->\n  <section data-screen-label=\"Testimonials\" style=\"padding:clamp(72px,9vw,120px) 24px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"text-align:center; max-width:560px; margin:0 auto clamp(40px,5vw,60px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Voices of the community<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0; line-height:1.12\">Why we give<\u002Fh2>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:22px\">\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:34px; box-shadow:0 10px 34px rgba(23,37,84,.05); display:flex; flex-direction:column; gap:20px\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:44px; line-height:.6; color:#D4AF37\">\"<\u002Fdiv>\n          <p style=\"margin:0; font-size:15px; line-height:1.75; font-style:italic; color:#3A4265\">My children were born here in Switzerland. This temple means they will grow up knowing who they are — with Krishna at the centre of their lives.<\u002Fp>\n          <div style=\"display:flex; align-items:center; gap:14px; margin-top:auto\">\n            <div style=\"width:48px; height:48px; border-radius:50%; overflow:hidden; flex-shrink:0\">\n              <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"quote-1\" shape=\"circle\" placeholder=\"\" hint-size=\"48px,48px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n            <\u002Fdiv>\n            <div>\n              <div style=\"font-size:14px; font-weight:700; color:#1B2A5E\">Kavitha Raman<\u002Fdiv>\n              <div style=\"font-size:12px; color:#8A92AC\">Brick sponsor · Lausanne<\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:34px; box-shadow:0 10px 34px rgba(23,37,84,.05); display:flex; flex-direction:column; gap:20px\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:44px; line-height:.6; color:#D4AF37\">\"<\u002Fdiv>\n          <p style=\"margin:0; font-size:15px; line-height:1.75; font-style:italic; color:#3A4265\">I sponsored a pillar in memory of my father. Knowing his name will stand in Krishna's home for generations — there is no greater gift.<\u002Fp>\n          <div style=\"display:flex; align-items:center; gap:14px; margin-top:auto\">\n            <div style=\"width:48px; height:48px; border-radius:50%; overflow:hidden; flex-shrink:0\">\n              <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"quote-2\" shape=\"circle\" placeholder=\"\" hint-size=\"48px,48px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n            <\u002Fdiv>\n            <div>\n              <div style=\"font-size:14px; font-weight:700; color:#1B2A5E\">Vikram Mehta<\u002Fdiv>\n              <div style=\"font-size:12px; color:#8A92AC\">Pillar sponsor · Zug<\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; padding:34px; box-shadow:0 10px 34px rgba(23,37,84,.05); display:flex; flex-direction:column; gap:20px\">\n          <div style=\"font-family:'EB Garamond',serif; font-size:44px; line-height:.6; color:#D4AF37\">\"<\u002Fdiv>\n          <p style=\"margin:0; font-size:15px; line-height:1.75; font-style:italic; color:#3A4265\">As a Swiss friend of the community, I'm moved by the openness of this project. The yoga and Gita classes have enriched my life deeply.<\u002Fp>\n          <div style=\"display:flex; align-items:center; gap:14px; margin-top:auto\">\n            <div style=\"width:48px; height:48px; border-radius:50%; overflow:hidden; flex-shrink:0\">\n              <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"quote-3\" shape=\"circle\" placeholder=\"\" hint-size=\"48px,48px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n            <\u002Fdiv>\n            <div>\n              <div style=\"font-size:14px; font-weight:700; color:#1B2A5E\">Martin Keller<\u002Fdiv>\n              <div style=\"font-size:12px; color:#8A92AC\">Monthly donor · Lucerne<\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 14 · LATEST UPDATES ══════════ -->\n  <section id=\"news\" data-screen-label=\"Latest Updates\" style=\"padding:clamp(72px,9vw,120px) 24px; background:#F3F4F8; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"display:flex; flex-wrap:wrap; align-items:flex-end; justify-content:space-between; gap:20px; margin-bottom:clamp(36px,4vw,56px)\">\n        <div>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">News<\u002Fdiv>\n          <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0; line-height:1.12\">Latest updates<\u002Fh2>\n        <\u002Fdiv>\n        <a href=\"#news\" style=\"text-decoration:none; color:#1E3A8A; font-size:14px; font-weight:700; display:flex; align-items:center; gap:8px\" style-hover=\"color:#16295F\">All updates <span style=\"font-size:16px\">→<\u002Fspan><\u002Fa>\n      <\u002Fdiv>\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:22px\">\n        <article data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; overflow:hidden; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"height:200px\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"news-1\" shape=\"rect\" radius=\"0\" placeholder=\"Photo: permit ceremony\" src=\"uploads/permit.png\" hint-size=\"100%,200px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <div style=\"padding:26px\">\n            <div style=\"font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">May 2026 · Milestone<\u002Fdiv>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px; line-height:1.25\">Building permit officially granted<\u002Fh3>\n            <p style=\"margin:0 0 16px; font-size:14px; line-height:1.65\">After two years of careful planning with cantonal authorities, our building permit has been approved without objections.<\u002Fp>\n            <a href=\"#news\" style=\"text-decoration:none; color:#1E3A8A; font-size:14px; font-weight:700\">Read update →<\u002Fa>\n          <\u002Fdiv>\n        <\u002Farticle>\n        <article data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; overflow:hidden; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"height:200px\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"news-2\" shape=\"rect\" radius=\"0\" placeholder=\"Photo: community celebration\" src=\"uploads/milestone.png\" hint-size=\"100%,200px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <div style=\"padding:26px\">\n            <div style=\"font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">March 2026 · Fundraising<\u002Fdiv>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px; line-height:1.25\">CHF 1.5 million milestone reached<\u002Fh3>\n            <p style=\"margin:0 0 16px; font-size:14px; line-height:1.65\">Over a thousand supporters across Switzerland and beyond have carried us past the halfway mark of our goal.<\u002Fp>\n            <a href=\"#news\" style=\"text-decoration:none; color:#1E3A8A; font-size:14px; font-weight:700\">Read update →<\u002Fa>\n          <\u002Fdiv>\n        <\u002Farticle>\n        <article data-reveal=\"\" style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:22px; overflow:hidden; box-shadow:0 10px 34px rgba(23,37,84,.05); transition:transform .25s, box-shadow .25s\" style-hover=\"transform:translateY(-4px); box-shadow:0 20px 44px rgba(23,37,84,.1)\">\n          <div style=\"height:200px\">\n            <x-import component-from-global-scope=\"image-slot\" from=\"193897a2-6c8f-4b00-9fe9-b3435db52c17#/image-slot.js\" id=\"news-3\" shape=\"rect\" radius=\"0\" placeholder=\"Render: unveiled architectural plans\" src=\"uploads/architect.png\" hint-size=\"100%,200px\" style=\"width:100%; height:100%\"><\u002Fx-import>\n          <\u002Fdiv>\n          <div style=\"padding:26px\">\n            <div style=\"font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#A8821F; margin-bottom:10px\">January 2026 · Design<\u002Fdiv>\n            <h3 style=\"font-family:'EB Garamond',serif; font-size:24px; font-weight:600; color:#1B2A5E; margin:0 0 10px; line-height:1.25\">Final architectural plans unveiled<\u002Fh3>\n            <p style=\"margin:0 0 16px; font-size:14px; line-height:1.65\">Traditional shilpis and Swiss architects presented the final Nagara-style design to 400 members in Zürich.<\u002Fp>\n            <a href=\"#news\" style=\"text-decoration:none; color:#1E3A8A; font-size:14px; font-weight:700\">Read update →<\u002Fa>\n          <\u002Fdiv>\n        <\u002Farticle>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 15 · FAQ ══════════ -->\n  <section data-screen-label=\"FAQ\" style=\"padding:clamp(72px,9vw,120px) 24px\">\n    <div style=\"max-width:820px; margin:0 auto\">\n      <div data-reveal=\"\" style=\"text-align:center; margin-bottom:clamp(36px,4vw,56px)\">\n        <div style=\"font-size:12px; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#A8821F; margin-bottom:14px\">Questions<\u002Fdiv>\n        <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(32px,4vw,48px); color:#1B2A5E; margin:0; line-height:1.12\">Frequently asked<\u002Fh2>\n      <\u002Fdiv>\n      <div data-reveal=\"\" style=\"display:flex; flex-direction:column; gap:14px\">\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">Are donations tax-deductible?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">Yes. The Indian Association in Switzerland is a registered non-profit, and donations are tax-deductible in most cantons. You receive an official donation receipt for your tax declaration each January.<\u002Fp>\n        <\u002Fdetails>\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">How is my donation used?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">100% of donations go to the temple project fund, held in a dedicated Swiss bank account. Finances are audited annually by an independent auditor and published in our yearly report to all members.<\u002Fp>\n        <\u002Fdetails>\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">When will construction begin?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">Groundbreaking is planned for spring 2027, once fundraising reaches 85% of the goal. The building permit is already granted, so construction can start as soon as funding allows.<\u002Fp>\n        <\u002Fdetails>\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">Can I donate from outside Switzerland?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">Absolutely. We accept international bank transfers and card payments in CHF, EUR, USD, and INR. Devotees from 14 countries have already contributed.<\u002Fp>\n        <\u002Fdetails>\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">Will my sponsorship be recognised?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">Every sponsor is recorded in the temple's permanent donor book. Pillar and sanctum sponsors may dedicate their contribution in the name of a loved one, inscribed within the temple.<\u002Fp>\n        <\u002Fdetails>\n        <details style=\"background:#fff; border:1px solid rgba(30,58,138,.08); border-radius:18px; box-shadow:0 8px 28px rgba(23,37,84,.04); overflow:hidden\">\n          <summary style=\"display:flex; justify-content:space-between; align-items:center; gap:16px; cursor:pointer; padding:22px 26px; font-family:'EB Garamond',serif; font-size:21px; font-weight:600; color:#1B2A5E; list-style:none\">How can I volunteer?<span style=\"color:#A8821F; font-size:20px; font-weight:400; flex-shrink:0\">+<\u002Fspan><\u002Fsummary>\n          <p style=\"margin:0; padding:0 26px 24px; font-size:15px; line-height:1.7\">We welcome help with events, translation, communications, and professional expertise in construction, law, and finance. Write to us at seva@krishnamandir.ch and we'll find the right seva for you.<\u002Fp>\n        <\u002Fdetails>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 16 · NEWSLETTER ══════════ -->\n  <section data-screen-label=\"Newsletter\" style=\"padding:0 24px clamp(72px,9vw,120px)\">\n    <div data-reveal=\"\" style=\"max-width:820px; margin:0 auto; background:#fff; border:1px solid rgba(212,175,55,.35); border-radius:28px; box-shadow:0 16px 50px rgba(23,37,84,.07); padding:clamp(32px,5vw,56px); text-align:center\">\n      <div style=\"color:#D4AF37; font-size:14px; margin-bottom:16px\">✦<\u002Fdiv>\n      <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(28px,3.4vw,40px); color:#1B2A5E; margin:0 0 12px; line-height:1.15\">Follow the temple's journey<\u002Fh2>\n      <p style=\"margin:0 0 28px; font-size:15px; line-height:1.7; max-width:440px; margin-left:auto; margin-right:auto\">Construction milestones, festival invitations, and community news. One email a month, no more.<\u002Fp>\n      <sc-if value=\"{{ notSubscribed }}\" hint-placeholder-val=\"{{ true }}\">\n        <form onsubmit=\"{{ onSubscribe }}\" style=\"display:flex; flex-wrap:wrap; gap:12px; justify-content:center; max-width:480px; margin:0 auto\">\n          <input type=\"email\" required=\"\" placeholder=\"Your email address\" style=\"flex:1 1 240px; background:#FAF8F3; border:1px solid rgba(30,58,138,.15); border-radius:999px; padding:15px 24px; font-family:Manrope,sans-serif; font-size:15px; color:#1B2A5E; outline:none\">\n          <button type=\"submit\" style=\"background:#1E3A8A; color:#fff; border:none; font-family:Manrope,sans-serif; font-size:15px; font-weight:700; padding:15px 32px; border-radius:999px; cursor:pointer; transition:background .2s\" style-hover=\"background:#16295F\">Subscribe<\u002Fbutton>\n        <\u002Fform>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ subscribed }}\" hint-placeholder-val=\"{{ false }}\">\n        <div style=\"display:inline-flex; align-items:center; gap:10px; background:rgba(30,58,138,.06); border-radius:999px; padding:14px 28px; font-size:15px; font-weight:600; color:#1E3A8A\">✦ Thank you — you're on the list. Hare Krishna!<\u002Fdiv>\n      <\u002Fsc-if>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ 17 · FINAL CTA ══════════ -->\n  <section data-screen-label=\"Final CTA\" style=\"position:relative; padding:clamp(90px,12vw,160px) 24px; background:linear-gradient(180deg,#16295F 0%,#1E3A8A 100%); overflow:hidden; text-align:center\">\n    <div style=\"position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 60% 55% at 50% 100%, rgba(212,175,55,.2), transparent 70%)\"><\u002Fdiv>\n    <div style=\"position:absolute; top:-120px; left:50%; transform:translateX(-50%); width:600px; height:600px; border-radius:50%; border:1px solid rgba(255,255,255,.07); pointer-events:none\"><\u002Fdiv>\n    <div style=\"position:absolute; top:-60px; left:50%; transform:translateX(-50%); width:440px; height:440px; border-radius:50%; border:1px solid rgba(255,255,255,.06); pointer-events:none\"><\u002Fdiv>\n    <div data-reveal=\"\" style=\"position:relative; max-width:760px; margin:0 auto\">\n      <div style=\"color:#E8C95C; font-size:16px; margin-bottom:24px\">✦<\u002Fdiv>\n      <h2 style=\"font-family:'EB Garamond',serif; font-weight:600; font-size:clamp(36px,5.4vw,66px); color:#fff; margin:0 0 20px; line-height:1.1; text-wrap:balance\">Together, We Build More Than a Temple<\u002Fh2>\n      <p style=\"font-size:clamp(17px,1.8vw,21px); line-height:1.6; color:rgba(255,255,255,.82); margin:0 0 40px\">We build a spiritual home for future generations.<\u002Fp>\n      <a href=\"#donate\" style=\"display:inline-block; text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:18px; font-weight:800; padding:20px 56px; border-radius:999px; box-shadow:0 14px 40px rgba(196,155,40,.4); transition:transform .2s, box-shadow .2s\" style-hover=\"transform:translateY(-3px); box-shadow:0 22px 54px rgba(196,155,40,.5)\">Donate Now<\u002Fa>\n      <div style=\"margin-top:22px; font-size:13px; color:rgba(255,255,255,.55)\">Every contribution, of any size, is a sacred offering<\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- ══════════ FOOTER ══════════ -->\n  <footer id=\"contact\" data-screen-label=\"Footer\" style=\"background:#0E1B44; color:rgba(255,255,255,.75); padding:clamp(56px,7vw,80px) 24px 0; scroll-margin-top:76px\">\n    <div style=\"max-width:1180px; margin:0 auto\">\n      <div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(230px,1fr)); gap:44px; padding-bottom:48px\">\n        <div>\n          <div style=\"display:flex; align-items:center; gap:12px; margin-bottom:18px\">\n            <div style=\"width:40px; height:40px; border-radius:50%; background:radial-gradient(circle at 35% 30%, #2A4CA8, #16295F); border:1px solid rgba(212,175,55,.4); display:flex; align-items:center; justify-content:center\">\n              <span style=\"color:#E8C95C; font-family:'EB Garamond',serif; font-size:19px; font-weight:600; line-height:1\">ॐ<\u002Fspan>\n            <\u002Fdiv>\n            <div>\n              <div style=\"font-family:'EB Garamond',serif; font-size:19px; font-weight:600; color:#fff; line-height:1.1\">Shri Krishna Mandir<\u002Fdiv>\n              <div style=\"font-size:10px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:#C49B28\">Indian Association in Switzerland<\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fdiv>\n          <p style=\"margin:0 0 20px; font-size:14px; line-height:1.7\">Building Switzerland's first traditional Krishna temple — by the community, for generations.<\u002Fp>\n          <div style=\"display:flex; gap:10px\">\n            <a href=\"#contact\" aria-label=\"Instagram\" style=\"width:38px; height:38px; border-radius:50%; border:1px solid rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; text-decoration:none; color:rgba(255,255,255,.8); font-size:11px; font-weight:700; transition:border-color .2s, color .2s\" style-hover=\"border-color:#C49B28; color:#E8C95C\">IG<\u002Fa>\n            <a href=\"#contact\" aria-label=\"Facebook\" style=\"width:38px; height:38px; border-radius:50%; border:1px solid rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; text-decoration:none; color:rgba(255,255,255,.8); font-size:11px; font-weight:700; transition:border-color .2s, color .2s\" style-hover=\"border-color:#C49B28; color:#E8C95C\">FB<\u002Fa>\n            <a href=\"#contact\" aria-label=\"YouTube\" style=\"width:38px; height:38px; border-radius:50%; border:1px solid rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; text-decoration:none; color:rgba(255,255,255,.8); font-size:11px; font-weight:700; transition:border-color .2s, color .2s\" style-hover=\"border-color:#C49B28; color:#E8C95C\">YT<\u002Fa>\n            <a href=\"#contact\" aria-label=\"WhatsApp\" style=\"width:38px; height:38px; border-radius:50%; border:1px solid rgba(255,255,255,.2); display:flex; align-items:center; justify-content:center; text-decoration:none; color:rgba(255,255,255,.8); font-size:11px; font-weight:700; transition:border-color .2s, color .2s\" style-hover=\"border-color:#C49B28; color:#E8C95C\">WA<\u002Fa>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:#E8C95C; margin-bottom:18px\">Quick links<\u002Fdiv>\n          <div style=\"display:flex; flex-direction:column; gap:12px\">\n            <a href=\"#about\" style=\"text-decoration:none; color:rgba(255,255,255,.75); font-size:14px; transition:color .2s\" style-hover=\"color:#fff\">About the association<\u002Fa>\n            <a href=\"#project\" style=\"text-decoration:none; color:rgba(255,255,255,.75); font-size:14px; transition:color .2s\" style-hover=\"color:#fff\">Temple project<\u002Fa>\n            <a href=\"#events\" style=\"text-decoration:none; color:rgba(255,255,255,.75); font-size:14px; transition:color .2s\" style-hover=\"color:#fff\">Events &amp; festivals<\u002Fa>\n            <a href=\"#gallery\" style=\"text-decoration:none; color:rgba(255,255,255,.75); font-size:14px; transition:color .2s\" style-hover=\"color:#fff\">Gallery<\u002Fa>\n            <a href=\"#news\" style=\"text-decoration:none; color:rgba(255,255,255,.75); font-size:14px; transition:color .2s\" style-hover=\"color:#fff\">Latest updates<\u002Fa>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:#E8C95C; margin-bottom:18px\">Contact<\u002Fdiv>\n          <div style=\"display:flex; flex-direction:column; gap:12px; font-size:14px; line-height:1.6\">\n            <div>Indian Association in Switzerland<br>Postfach 1108<br>8021 Zürich, Switzerland<\u002Fdiv>\n            <a href=\"mailto:info@krishnamandir.ch\" style=\"text-decoration:none; color:rgba(255,255,255,.75); transition:color .2s\" style-hover=\"color:#fff\">info@krishnamandir.ch<\u002Fa>\n            <a href=\"tel:+41441234567\" style=\"text-decoration:none; color:rgba(255,255,255,.75); transition:color .2s\" style-hover=\"color:#fff\">+41 44 123 45 67<\u002Fa>\n          <\u002Fdiv>\n        <\u002Fdiv>\n        <div>\n          <div style=\"font-size:12px; font-weight:700; letter-spacing:.18em; text-transform:uppercase; color:#E8C95C; margin-bottom:18px\">Support the temple<\u002Fdiv>\n          <p style=\"margin:0 0 18px; font-size:14px; line-height:1.7\">Your gift builds a sacred home that will serve generations.<\u002Fp>\n          <a href=\"#donate\" style=\"display:inline-block; text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:14px; font-weight:800; padding:13px 32px; border-radius:999px; transition:transform .2s\" style-hover=\"transform:translateY(-2px)\">Donate<\u002Fa>\n          <p style=\"margin:20px 0 0; font-size:12px; line-height:1.7; color:rgba(255,255,255,.5)\">Registered non-profit association (Verein) under Art. 60 ff. Swiss Civil Code · UID CHE-123.456.789 · Donations tax-deductible in most cantons<\u002Fp>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"border-top:1px solid rgba(255,255,255,.1); padding:24px 0; display:flex; flex-wrap:wrap; justify-content:space-between; gap:12px; font-size:13px; color:rgba(255,255,255,.45)\">\n        <div>© 2026 Indian Association in Switzerland. All rights reserved.<\u002Fdiv>\n        <div style=\"display:flex; gap:20px\">\n          <a href=\"#contact\" style=\"text-decoration:none; color:rgba(255,255,255,.45); transition:color .2s\" style-hover=\"color:rgba(255,255,255,.8)\">Privacy<\u002Fa>\n          <a href=\"#contact\" style=\"text-decoration:none; color:rgba(255,255,255,.45); transition:color .2s\" style-hover=\"color:rgba(255,255,255,.8)\">Statutes<\u002Fa>\n          <a href=\"#contact\" style=\"text-decoration:none; color:rgba(255,255,255,.45); transition:color .2s\" style-hover=\"color:rgba(255,255,255,.8)\">Imprint<\u002Fa>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Ffooter>\n\n  <!-- Floating: back to top -->\n  <sc-if value=\"{{ showTop }}\" hint-placeholder-val=\"{{ false }}\">\n    <button onclick=\"{{ scrollTop }}\" aria-label=\"Back to top\" style=\"position:fixed; right:20px; bottom:{{ topBtnBottom }}; z-index:70; width:48px; height:48px; border-radius:50%; background:rgba(255,255,255,.92); backdrop-filter:blur(10px); border:1px solid rgba(30,58,138,.15); color:#1E3A8A; font-size:18px; cursor:pointer; box-shadow:0 10px 30px rgba(23,37,84,.18); transition:transform .2s\" style-hover=\"transform:translateY(-3px)\">↑<\u002Fbutton>\n  <\u002Fsc-if>\n\n  <!-- Sticky mobile donate bar -->\n  <sc-if value=\"{{ isMobile }}\" hint-placeholder-val=\"{{ false }}\">\n    <div style=\"position:fixed; left:0; right:0; bottom:0; z-index:75; background:rgba(250,248,243,.92); backdrop-filter:blur(16px); border-top:1px solid rgba(30,58,138,.1); padding:12px 16px calc(12px + env(safe-area-inset-bottom)); display:flex; align-items:center; gap:14px\">\n      <div style=\"flex:1; min-width:0\">\n        <div style=\"font-size:13px; font-weight:800; color:#1B2A5E\">CHF {{ raisedFmt }} raised<\u002Fdiv>\n        <div style=\"height:5px; border-radius:999px; background:#E6E9F2; overflow:hidden; margin-top:5px\"><div style=\"height:100%; width:{{ barW }}; border-radius:999px; background:linear-gradient(90deg,#1E3A8A,#C49B28)\"><\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n      <a href=\"#donate\" style=\"text-decoration:none; background:linear-gradient(135deg,#E9CA66,#C49B28); color:#2A1F04; font-size:15px; font-weight:800; padding:14px 28px; border-radius:999px; box-shadow:0 8px 22px rgba(196,155,40,.35); flex-shrink:0\">Donate<\u002Fa>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n<\u002Fdiv>\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{\n  &quot;raisedChf&quot;: { &quot;editor&quot;: &quot;int&quot;, &quot;default&quot;: 1635000, &quot;tsType&quot;: &quot;number&quot;, &quot;min&quot;: 0, &quot;section&quot;: &quot;Fundraising&quot; },\n  &quot;goalChf&quot;: { &quot;editor&quot;: &quot;int&quot;, &quot;default&quot;: 2500000, &quot;tsType&quot;: &quot;number&quot;, &quot;min&quot;: 1, &quot;section&quot;: &quot;Fundraising&quot; },\n  &quot;supporters&quot;: { &quot;editor&quot;: &quot;int&quot;, &quot;default&quot;: 1284, &quot;tsType&quot;: &quot;number&quot;, &quot;min&quot;: 0, &quot;section&quot;: &quot;Fundraising&quot; }\n}\">\nclass Component extends DCLogic {\n  state = {\n    menuOpen: false,\n    isMobile: false,\n    showTop: false,\n    barPct: 0,\n    subscribed: false\n  };\n\n  componentDidMount() {\n    // Responsive flag\n    this._mq = window.matchMedia('(max-width: 900px)');\n    this._onMq = () => this.setState({ isMobile: this._mq.matches, menuOpen: false });\n    this._mq.addEventListener('change', this._onMq);\n    this.setState({ isMobile: this._mq.matches });\n\n    // Back-to-top visibility (setState only when crossing threshold)\n    this._onScroll = () => {\n      const show = window.scrollY > 800;\n      if (show !== this.state.showTop) this.setState({ showTop: show });\n    };\n    window.addEventListener('scroll', this._onScroll, { passive: true });\n\n    // Animate progress bars in\n    this._barTimer = setTimeout(() => this.setState({ barPct: this._pct() }), 350);\n\n    // Scroll-reveal via WAAPI (doesn't touch style attr, survives re-renders)\n    this._revealed = new WeakSet();\n    this._io = new IntersectionObserver((entries) => {\n      entries.forEach((e) => {\n        if (!e.isIntersecting || this._revealed.has(e.target)) return;\n        this._revealed.add(e.target);\n        e.target.animate(\n          [{ opacity: 0, transform: 'translateY(26px)' }, { opacity: 1, transform: 'translateY(0)' }],\n          { duration: 750, easing: 'cubic-bezier(.22,1,.36,1)' }\n        );\n        this._io.unobserve(e.target);\n      });\n    }, { threshold: 0.12 });\n    document.querySelectorAll('[data-reveal]').forEach((el) => this._io.observe(el));\n  }\n\n  componentWillUnmount() {\n    if (this._mq) this._mq.removeEventListener('change', this._onMq);\n    window.removeEventListener('scroll', this._onScroll);\n    clearTimeout(this._barTimer);\n    if (this._io) this._io.disconnect();\n  }\n\n  _raised() { return this.props.raisedChf ?? 1635000; }\n  _goal() { return this.props.goalChf ?? 2500000; }\n  _pct() {\n    const g = this._goal();\n    return g > 0 ? Math.min(100, Math.round((this._raised() / g) * 100)) : 0;\n  }\n  _fmt(n) {\n    return Math.round(n).toString().replace(/\\B(?=(\\d{3})+(?!\\d))/g, \"'\");\n  }\n\n  renderVals() {\n    const supporters = this.props.supporters ?? 1284;\n    return {\n      raisedFmt: this._fmt(this._raised()),\n      goalFmt: this._fmt(this._goal()),\n      supportersFmt: this._fmt(supporters),\n      pct: this._pct(),\n      barW: this.state.barPct + '%',\n      isMobile: this.state.isMobile,\n      isDesktop: !this.state.isMobile,\n      menuOpen: this.state.menuOpen && this.state.isMobile,\n      toggleMenu: () => this.setState(s => ({ menuOpen: !s.menuOpen })),\n      closeMenu: () => this.setState({ menuOpen: false }),\n      showTop: this.state.showTop,\n      topBtnBottom: this.state.isMobile ? '92px' : '24px',\n      scrollTop: () => window.scrollTo({ top: 0, behavior: 'smooth' }),\n      subscribed: this.state.subscribed,\n      notSubscribed: !this.state.subscribed,\n      onSubscribe: (e) => { e.preventDefault(); this.setState({ subscribed: true }); }\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>

</html>